# Stripe price IDs — add to Vercel environment variables (VITE_ prefix = exposed to browser)
VITE_STRIPE_PRICE_PRO_MONTHLY=price_...
VITE_STRIPE_PRICE_PRO_ANNUAL=price_...
VITE_STRIPE_PRICE_ELITE_MONTHLY=price_...
VITE_STRIPE_PRICE_ELITE_ANNUAL=price_...

# Server-side keys — add to Vercel env vars (NO VITE_ prefix = server only)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # From Supabase → Settings → API → service_role
