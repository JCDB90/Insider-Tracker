# ─────────────────────────────────────────────────────────────────────────────
# Insider Tracker — Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   nano .env
#
# NEVER commit .env to git (it's in .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
# Find these in: Supabase dashboard → Settings → API
#
# Use the service_role key (not anon) so the scraper can bypass Row Level
# Security and write to all tables without authentication.

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-service-role-key-here

# ── Runtime ───────────────────────────────────────────────────────────────────

NODE_ENV=production

# ── Puppeteer ─────────────────────────────────────────────────────────────────
# Point to the system-installed Chromium to avoid downloading a 300 MB bundle.
# After running deploy.sh this is set automatically.
#
# Ubuntu / Debian:
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
#
# macOS (via Homebrew):
# PUPPETEER_EXECUTABLE_PATH=/usr/local/bin/chromium
#
# Windows WSL2 (local dev — Puppeteer usually not needed):
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
